<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>JMSAutoMapper</id>
    <version>1.0.2</version>
    <title>JMS Auto Mapper</title>
    <authors>José Mendes da Silva</authors>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>JmsMapperIcon.png</icon>
    <readme>README.md</readme>
    <description>Framework para a transferência de Dados entre objetos. Inclusive, entre objetos relacionais. Este pacote é um pacote Demo, em sua versão atual, e pode se usado livremente, desde de que respeito os direitos autorais.</description>
    <releaseNotes>Esta é a versão piloto, alterada para incluir o mapeamento de colections</releaseNotes>
    <copyright>Created By JMS</copyright>
    <tags>JMS, JMSAutoMapper, JMS, Transferencia, Objeto, Relacional</tags>
    <repository type="git" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="System.Collections.Immutable" version="9.0.4" exclude="Build,Analyzers" />
        <dependency id="System.Runtime.Caching" version="9.0.4" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
